# Copia este archivo a .env.local y rellena los valores.
# SOLO se usa la anon key en el cliente. La service_role key NUNCA va aquí ni en el repo.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# (Opcional, solo para `npm run gen:types`) id del proyecto Supabase. No se usa en el cliente.
SUPABASE_PROJECT_ID=
